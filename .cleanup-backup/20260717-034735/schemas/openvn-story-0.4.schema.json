{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openvn.org/schemas/openvn-story-0.4.schema.json",
  "title": "OpenVN Story 0.4",
  "type": "object",
  "required": [
    "format",
    "version",
    "entry",
    "symbols",
    "nodes"
  ],
  "properties": {
    "format": {
      "const": "openvn-story"
    },
    "version": {
      "const": "0.4"
    },
    "entry": {
      "type": "string",
      "minLength": 1
    },
    "symbols": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1
    }
  },
  "additionalProperties": false
}
