{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openvn.org/schemas/openvn-story-0.3.schema.json",
  "title": "OpenVN Story 0.3",
  "type": "object",
  "required": [
    "format",
    "version",
    "entry",
    "symbols",
    "nodes"
  ],
  "properties": {
    "format": {
      "const": "openvn-story"
    },
    "version": {
      "const": "0.3"
    },
    "entry": {
      "type": "string",
      "minLength": 1
    },
    "symbols": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": [
              "id",
              "type",
              "text",
              "next"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "const": "text"
              },
              "text": {
                "type": "string"
              },
              "next": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": [
              "id",
              "type",
              "options"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "const": "choice"
              },
              "options": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": [
                    "text",
                    "target"
                  ],
                  "properties": {
                    "text": {
                      "type": "string",
                      "minLength": 1
                    },
                    "target": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": [
              "id",
              "type",
              "target"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "const": "jump"
              },
              "target": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": [
              "id",
              "type"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "const": "end"
              }
            },
            "additionalProperties": false
          }
        ]
      }
    }
  },
  "additionalProperties": false
}
